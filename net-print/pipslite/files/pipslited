start () {
	ebegin "Starting pipslited"
	start-stop-daemon --quiet --start --exec /usr/bin/pipslited
	eend $?
}

stop () {
	ebegin "Stopping pipslited"
	start-stop-daemon --quiet --stop --exec /usr/bin/pipslited
	rm $(grep DummyDevicePath /etc/pipslite/pipslitedrc | sed -e "s/.*=//")
	eend $?
}
