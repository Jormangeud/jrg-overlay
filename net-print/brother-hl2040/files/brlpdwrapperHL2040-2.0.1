# filter job user title num-copies options [filename]

echo "DEBUG2: brlpdwrapperHL2040 $*" 1>&2

filter='/usr/share/Brother/lpd/filterHL2040'

if [ -x $filter ]; then
       :
else
    echo "ERROR: $filter does not exist or not executable" 1>&2
    exit 30
fi

brcupsconfig3 $PRINTER $PPD 7 $options | sed -e 's/^/DEBUG2: /' 1>&2

if [ $# -ge 7 ]; then
    $filter < $6
else
    cat | $filter
fi
